// Bookment — multi-tenant bookings (PostgreSQL)

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  SUPER_ADMIN
  OWNER
  EMPLOYEE
}

enum BookingStatus {
  CONFIRMED
  CANCELLED
}

enum BlockReason {
  MANUAL
  VACATION
  HOLIDAY
}

enum TenantBillingCycle {
  MONTHLY
  ANNUAL
}

enum TenantExpenseKind {
  FIXED_ONE_TIME
  FIXED_MONTHLY
  DYNAMIC
}

model User {
  id                 String                   @id @default(cuid())
  email              String                   @unique
  emailVerified      DateTime?
  passwordHash       String
  name               String?
  image              String?
  role               Role                     @default(EMPLOYEE)
  tenantId           String?
  tenant             Tenant?                  @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  staffProfile       Staff?                   @relation("UserStaff")
  passwordResets     PasswordResetToken[]
  emailVerifications EmailVerificationToken[]
  createdAt          DateTime                 @default(now())
  updatedAt          DateTime                 @updatedAt

  @@index([tenantId])
}

model EmailVerificationToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

/// Código de alta de un solo uso (solo se guarda el hash).
model SignupInviteCode {
  id        String    @id @default(cuid())
  codeHash  String    @unique
  usedAt    DateTime?
  note      String?
  createdAt DateTime  @default(now())

  @@index([usedAt])
}

/// Precios de lista Simple/Premium (ARS). El super admin los edita en /admin/economia.
/// reporting* y configChangedAt son legacy; el código alinea todo con los precios guardados.
model PlatformPricing {
  id                   String    @id
  configuredSimpleArs  Int
  configuredPremiumArs Int
  reportingSimpleArs   Int
  reportingPremiumArs  Int
  configChangedAt      DateTime?
  updatedAt            DateTime  @updatedAt
}

/// Congelado la primera vez que se abre Economía en cada mes calendario (timezone AR).
model EconomiaMonthSnapshot {
  monthKey        String   @id
  activeSimple    Int
  activePremium   Int
  priceSimpleArs  Int
  pricePremiumArs Int
  mrrTotalArs     Int
  createdAt       DateTime @default(now())
}

model Tenant {
  id                   String                 @id @default(cuid())
  slug                 String                 @unique
  businessType         String?
  name                 String
  logoUrl              String?
  whatsapp             String?
  location             String?
  onboardingDone       Boolean                @default(false)
  onboardingStep       Int                    @default(0)
  subscriptionTier     String                 @default("simple")
  /// Si es true, todos los profesionales ofrecen los mismos servicios activos (comportamiento clásico).
  /// Si es false, solo aplican las filas en StaffService.
  sameServicesAllStaff Boolean                @default(true)
  active               Boolean                @default(true)
  /// Notas internas del super admin (no se muestran al cliente).
  adminNotes           String?
  settings             Json?
  users                User[]
  staff                Staff[]
  services             Service[]
  workingHours         WorkingHour[]
  blockedSlots         BlockedSlot[]
  bookings             Booking[]
  billingPayments      TenantBillingPayment[]
  expenses             TenantExpense[]
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt

  @@index([active])
}

model Staff {
  id            String         @id @default(cuid())
  tenantId      String
  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId        String?        @unique
  user          User?          @relation("UserStaff", fields: [userId], references: [id])
  name          String
  title         String?
  commissionPercent Int        @default(0)
  active        Boolean        @default(true)
  bookings      Booking[]
  workingHours  WorkingHour[]
  blockedSlots  BlockedSlot[]
  staffServices StaffService[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([tenantId])
  @@index([tenantId, active])
}

model Service {
  id               String         @id @default(cuid())
  tenantId         String
  tenant           Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name             String
  durationMinutes  Int
  priceCents       Int?
  currency         String         @default("ARS")
  active           Boolean        @default(true)
  bookings         Booking[]
  staffAssignments StaffService[]
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@index([tenantId])
  @@index([tenantId, active])
}

/// Servicios que ofrece cada profesional (solo aplica si Tenant.sameServicesAllStaff es false).
model StaffService {
  staffId   String
  serviceId String
  staff     Staff   @relation(fields: [staffId], references: [id], onDelete: Cascade)
  service   Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@id([staffId, serviceId])
  @@index([serviceId])
}

model WorkingHour {
  id        String  @id @default(cuid())
  tenantId  String
  tenant    Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  staffId   String?
  staff     Staff?  @relation(fields: [staffId], references: [id], onDelete: Cascade)
  dayOfWeek Int
  opensAt   String
  closesAt  String

  @@index([tenantId, staffId, dayOfWeek])
}

model BlockedSlot {
  id        String      @id @default(cuid())
  tenantId  String
  tenant    Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  staffId   String?
  staff     Staff?      @relation(fields: [staffId], references: [id], onDelete: Cascade)
  startsAt  DateTime
  endsAt    DateTime
  reason    BlockReason @default(MANUAL)
  note      String?
  createdAt DateTime    @default(now())

  @@index([tenantId, startsAt])
  @@index([staffId, startsAt])
}

model Booking {
  id            String        @id @default(cuid())
  tenantId      String
  tenant        Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  serviceId     String
  service       Service       @relation(fields: [serviceId], references: [id])
  staffId       String
  staff         Staff         @relation(fields: [staffId], references: [id])
  customerName  String
  customerPhone String
  customerEmail String?
  servicePriceCentsSnapshot Int?
  staffCommissionPercentSnapshot Int?
  staffPayoutArsSnapshot Int?
  startsAt      DateTime
  endsAt        DateTime
  status        BookingStatus @default(CONFIRMED)
  reminders     ReminderJob[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([tenantId, startsAt])
  @@index([staffId, startsAt])
  @@index([staffId, status, startsAt])
}

/// Cola preparada para recordatorios (ej. 24h antes) — worker/cron futuro
model ReminderJob {
  id        String    @id @default(cuid())
  bookingId String
  booking   Booking   @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  fireAt    DateTime
  channel   String    @default("whatsapp")
  payload   Json?
  sentAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([fireAt, sentAt])
}

model TenantBillingPayment {
  id           String             @id @default(cuid())
  tenantId     String
  tenant       Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  planId       String
  billingCycle TenantBillingCycle
  amountArs    Int
  paidAt       DateTime
  nextDueAt    DateTime
  note         String?
  createdAt    DateTime           @default(now())

  @@index([tenantId, paidAt])
  @@index([tenantId, nextDueAt])
}

model TenantExpense {
  id          String            @id @default(cuid())
  tenantId    String
  tenant      Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  kind        TenantExpenseKind
  name        String
  amountArs   Int
  expenseDate DateTime
  note        String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@index([tenantId, expenseDate])
  @@index([tenantId, kind, expenseDate])
}

